# Xcode
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
*.xcworkspace/*
!*.xcworkspace/contents.xcworkspacedata
!*.xcworkspace/xcshareddata/

# Swift Package Manager build cache (never commit — regenerates on build)
.build/
**/.build/
.swiftpm/
Package.resolved

# macOS
.DS_Store
*.swp
*.swo
*~.nib
DerivedData/
build/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
xcuserdata/

# Node
node_modules/
npm-debug.log
yarn-error.log
yarn.lock
package-lock.json

# Expo
.expo/
.expo-shared/
dist/
web-build/

# Misc
*.log
.env
.env.local

# Remote SPM packages (fetched via GitHub URLs in project.yml, not committed)
/AuthDomain/
/FeatureAuth/
/FirebaseAuthData/

# XcodeGen-generated project
/ScriptStarter.xcodeproj/

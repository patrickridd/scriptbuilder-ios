    "edit.delete.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden „%@“ und alle Inhalte dauerhaft entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This permanently removes “%@” and everything in it. This can’t be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina de forma permanente «%@» y todo su contenido. No se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime définitivement « %@ » et tout son contenu. Cette action est irréversible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह “%@” और इसमें मौजूद सब कुछ स्थायी रूप से हटा देता है। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」とその中身がすべて完全に削除されます。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”와(과) 그 안의 모든 항목이 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将永久删除“%@”及其全部内容。此操作无法撤销。"
          }
        }
      }
    },

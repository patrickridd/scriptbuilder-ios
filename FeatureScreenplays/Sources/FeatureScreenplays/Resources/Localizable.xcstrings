          "stringUnit" : {
            "state" : "translated",
            "value" : "删除角色"
          }
        }
      }
    },
    "character.delete.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ und ihr gesamter Handlungsbogen werden dauerhaft entfernt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ and their entire arc will be permanently removed. This can't be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ y todo su arco se eliminarán de forma permanente. Esto no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ et tout son arc seront définitivement supprimés. Cette action est irréversible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ और उनका पूरा आर्क स्थायी रूप से हटा दिया जाएगा। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ とそのアーク全体が完全に削除されます。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 및 전체 아크가 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 及其整个角色弧线将被永久删除。此操作无法撤销。"
          }
        }
      }
    },

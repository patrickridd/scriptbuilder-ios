    "home.empty.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben noch keine Drehbücher.\nBeginnen Sie Ihren ersten Entwurf, um ihn zum Leben zu erwecken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You don't have any screenplays yet.\nStart your first draft to bring it to life."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no tienes ningún guion.\nEmpieza tu primer borrador para darle vida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’avez encore aucun scénario.\nCommencez votre premier brouillon pour lui donner vie."

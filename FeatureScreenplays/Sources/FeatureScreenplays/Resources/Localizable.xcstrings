            "state" : "translated",
            "value" : "पात्र हटाएँ"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャラクターを削除"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캐릭터 삭제"
          }
        },

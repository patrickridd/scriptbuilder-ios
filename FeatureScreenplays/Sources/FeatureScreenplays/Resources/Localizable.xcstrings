    "character.empty.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bauen Sie Ihre Besetzung Bogen für Bogen auf. Tippen Sie auf +, um Ihren Protagonisten hinzuzufügen und zu formen, was er will, warum und wie er sich verändert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Build your cast one arc at a time. Tap the + to add your protagonist and shape what they want, why, and how they change."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construye tu elenco un arco a la vez. Toca + para añadir a tu protagonista y definir qué quiere, por qué y cómo cambia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Construisez votre distribution un arc à la fois. Touchez + pour ajouter votre protagoniste et définir ce qu’il veut, pourquoi et comment il change."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने पात्रों को एक-एक आर्क करके बनाएँ। अपने नायक को जोड़ने और यह तय करने के लिए + पर टैप करें कि वे क्या चाहते हैं, क्यों और कैसे बदलते हैं।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アークを一つずつ作り上げて登場人物を構築しましょう。+ をタップして主人公を追加し、その望み・理由・変化を形作りましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 번에 하나의 아크로 캐릭터를 구성하세요. +를 탭하여 주인공을 추가하고 그들이 원하는 것, 이유, 변화 방식을 만들어 보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一次构建一个角色弧线。点击 + 添加你的主角，并塑造他们想要什么、为什么以及如何改变。"
          }
        }
      }
    },

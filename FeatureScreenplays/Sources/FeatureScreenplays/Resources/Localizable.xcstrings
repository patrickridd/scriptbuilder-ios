        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके पास अभी तक कोई पटकथा नहीं है।\nइसे जीवंत करने के लिए अपना पहला ड्राफ़्ट शुरू करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",

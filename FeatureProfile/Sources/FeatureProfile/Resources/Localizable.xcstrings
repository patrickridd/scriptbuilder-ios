    "profile.danger.delete.message" : {
      "comment" : "Delete-account confirmation alert message.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden Ihr Konto und alle Ihre Drehbücher dauerhaft gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This permanently deletes your account and all of your screenplays. This can't be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina permanentemente tu cuenta y todos tus guiones. No se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime définitivement votre compte et tous vos scénarios. Cette action est irréversible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह आपके खाते और आपकी सभी पटकथाओं को स्थायी रूप से हटा देता है। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",

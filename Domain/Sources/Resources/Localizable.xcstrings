    "beat.oldWorldDescription.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wie sieht das Leben aus, bevor die Geschichte beginnt?" } },

    "auth.error.login.invalid" : {
      "comment" : "Validation error when login fields are invalid.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gib eine gültige E-Mail und ein Passwort mit mindestens 6 Zeichen ein." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enter a valid email and a password of at least 6 characters." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Introduce un correo válido y una contraseña de al menos 6 caracteres." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Saisissez une adresse e-mail valide et un mot de passe d’au moins 6 caractères." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "एक मान्य ईमेल और कम से कम 6 अक्षरों का पासवर्ड दर्ज करें।" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "有効なメールアドレスと6文字以上のパスワードを入力してください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "유효한 이메일과 6자 이상의 비밀번호를 입력하세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请输入有效的电子邮件和至少 6 个字符的密码。" } }
      }
    },
    "auth.error.reset.needEmail" : {
      "comment" : "Prompt to enter an email before requesting a password reset.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Gib oben deine E-Mail ein und tippe erneut auf „Passwort vergessen?“." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enter your email above, then tap “Forgot password?” again." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Introduce tu correo arriba y vuelve a tocar «¿Olvidaste tu contraseña?»." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Saisissez votre e-mail ci-dessus, puis touchez à nouveau « Mot de passe oublié ? »." } },
        "hi" : { "stringUnit" : { "state" : "translated", "value" : "ऊपर अपना ईमेल दर्ज करें, फिर “पासवर्ड भूल गए?” पर दोबारा टैप करें।" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "上にメールアドレスを入力してから、もう一度「パスワードをお忘れですか？」をタップしてください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "위에 이메일을 입력한 다음 “비밀번호를 잊으셨나요?”를 다시 탭하세요." } },
